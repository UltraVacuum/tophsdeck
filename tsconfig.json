{
    "compilerOptions": {
        "target": "esnext",
        "lib": ["esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "plugins": [],
        "baseUrl": ".",
        "outDir": "dist",
        "paths": {
            "@/*": ["./src/*"],
        },
    },
    "ts-node": {
        "esm": true,
    },
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules"],
}
