{
    "compilerOptions": {
        "target": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "node",
        "strict": true,
        "incremental": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "baseUrl": ".",
        "outDir": "dist",
    },
    "include": ["src"],
}
